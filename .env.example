# DeepRenPyTrans API Configuration
# Copy this file to .env and fill in your API key

# DeepSeek API (default provider)
DEEPSEEK_API_KEY=sk-your-key-here

# OpenAI API (alternative provider)
# OPENAI_API_KEY=sk-your-openai-key-here

# OpenRouter API (supports Qwen, Llama, Gemini, etc.)
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Groq API (super fast Llama 3)
# GROQ_API_KEY=gsk_your-groq-key-here

# Nebius AI Studio API
# NEBIUS_API_KEY=your-nebius-key-here

# DeepInfra API
# DEEPINFRA_API_KEY=your-deepinfra-key-here
